upstream mypress {
    server 127.0.0.1:8000;
}

# HTTP → HTTPS 重定向
server {
    listen 80;
    server_name YOUR_DOMAIN YOUR_WWW_DOMAIN;

    # Let's Encrypt 验证（申请证书时需要）
    location /.well-known/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$server_name$request_uri;
    }
}

# HTTPS 站点
server {
    listen 443 ssl http2;
    server_name YOUR_DOMAIN YOUR_WWW_DOMAIN;

    # SSL 证书（Let's Encrypt 或自行配置）
    ssl_certificate /etc/nginx/ssl/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/key.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    # 静态文件（Nginx 直接 serve，无需经过 Django）
    location /static/ {
        alias /var/www/static/;
        expires 30d;
        access_log off;
        add_header Cache-Control "public, immutable";
    }

    # 媒体文件（上传文件 + WordPress 迁移的图片等）
    location /media/ {
        alias /var/www/media/uploads/;
        expires 30d;
        access_log off;
    }

    # favicon
    location /favicon.ico {
        alias /var/www/static/images/favicon.ico;
        expires 30d;
        access_log off;
    }

    # 反向代理到 Django
    location / {
        proxy_pass http://mypress;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        client_max_body_size 50m;
    }
}
