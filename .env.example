# MyPress 环境变量配置
# 复制此文件为 .env 并修改相应值

# Django 必需设置
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# 数据库配置 (PostgreSQL)
DB_NAME=mypress
DB_USER=mypress
DB_PASSWORD=change-this-password-in-production
DB_HOST=db
DB_PORT=5432

# Redis 配置
REDIS_URL=redis://redis:6379/0

# 邮件配置 (可选)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-email-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=MyPress <noreply@example.com>

# 服务端口
MYPRESS_PORT=8000

# 时区
TIME_ZONE=Asia/Shanghai
LANGUAGE_CODE=zh-hans

# 评论设置
COMMENTS_REQUIRE_APPROVAL=False
COMMENTS_ALLOW_GUESTS=True

# 数据库统一URL (可选，与DB_*变量二选一)
# DATABASE_URL=postgres://mypress:password@db:5432/mypress
