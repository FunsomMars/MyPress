# MyPress 环境变量配置
# 复制此文件为 .env 并修改相应值
# 使用 deploy.sh 部署时会自动生成 SECRET_KEY 和 DB_PASSWORD

# ===== Django 核心 =====
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ===== 数据库 (PostgreSQL) =====
DB_NAME=mypress
DB_USER=mypress
DB_PASSWORD=change-this-password-in-production
DB_HOST=db
DB_PORT=5432
# 或使用统一 URL（与 DB_* 变量二选一）
# DATABASE_URL=postgres://mypress:password@db:5432/mypress

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== 服务配置 =====
MYPRESS_PORT=8000
TIME_ZONE=Asia/Shanghai
LANGUAGE_CODE=zh-hans

# ===== 站点自定义 =====
SITE_NAME=MyPress
HERO_TITLE=欢迎来到我的博客
HERO_SUBTITLE=分享技术、生活与创意
# FOOTER_TEXT=Copyright © 2026 MyPress
# SITE_SUBTITLE=

# ===== 超级管理员（首次部署自动创建，已存在则跳过）=====
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=change-this-password
SUPERUSER_EMAIL=admin@example.com

# ===== 评论设置 =====
COMMENTS_REQUIRE_APPROVAL=False
COMMENTS_ALLOW_GUESTS=True

# ===== 邮件配置（用于用户注册验证，可选）=====
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-email-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=MyPress <noreply@example.com>
