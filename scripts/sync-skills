#!/bin/bash
# OpenClaw Skills Sync - 快捷启动脚本

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_SCRIPT="$SCRIPT_DIR/sync-skills.py"

# 检查 Python 3 是否可用
if ! command -v python3 &> /dev/null; then
    echo "错误: 未找到 python3"
    exit 1
fi

# 执行 Python 脚本并传递所有参数
python3 "$PYTHON_SCRIPT" "$@"
